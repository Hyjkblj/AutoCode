{
  "schemaVersion": 1,
  "serviceId": "control-plane-api",
  "displayName": "Control Plane API",
  "ports": [
    { "name": "http", "port": 8080, "protocol": "http" }
  ],
  "healthCheck": {
    "path": "/actuator/health",
    "method": "GET",
    "portName": "http"
  },
  "environment": [
    {
      "name": "SPRING_PROFILES_ACTIVE",
      "description": "Spring profile(s) to activate",
      "required": false,
      "defaultValue": "dev"
    },
    {
      "name": "SERVER_PORT",
      "description": "HTTP listen port (optional override)",
      "required": false
    }
  ],
  "startup": {
    "command": "mvn",
    "workingDir": "control-plane-spring",
    "args": ["spring-boot:run"]
  }
}
