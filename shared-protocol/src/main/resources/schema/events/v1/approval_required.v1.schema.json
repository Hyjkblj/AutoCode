{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/events/v1/approval_required.v1.schema.json",
  "title": "APPROVAL_REQUIRED TaskEvent v1",
  "allOf": [
    { "$ref": "task_event.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "APPROVAL_REQUIRED" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["approvalId", "context"],
          "properties": {
            "approvalId": { "type": "string", "minLength": 1 },
            "traceId": { "type": "string", "minLength": 1 },
            "runId": { "type": "string", "minLength": 1 },
            "action": { "type": "string", "minLength": 1 },
            "tool": { "type": "string", "minLength": 1 },
            "command": { "type": "string", "minLength": 1 },
            "cwd": { "type": "string", "minLength": 1 },
            "workspaceRef": { "type": "string", "minLength": 1 },
            "approvalTimeoutSeconds": { "type": "integer", "minimum": 0 },
            "riskScore": { "type": "number", "minimum": 0, "maximum": 1 },
            "requiredPolicies": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "toolVersion": { "type": "string", "minLength": 1 },
            "reason": { "type": "string" },
            "context": {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "tool", "workspaceRef", "inputsHash"],
              "properties": {
                "action": { "type": "string", "minLength": 1 },
                "tool": { "type": "string", "minLength": 1 },
                "workspaceRef": { "type": "string", "minLength": 1 },
                "inputsHash": { "type": "string", "minLength": 1 },
                "inputs": { "type": "object" }
              }
            }
          }
        }
      }
    }
  ]
}

