{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/events/v1/task_failed.v1.schema.json",
  "title": "TASK_FAILED TaskEvent v1",
  "allOf": [
    { "$ref": "task_event.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "TASK_FAILED" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason"],
          "properties": {
            "reason": { "type": "string", "minLength": 1 },
            "detail": { "type": "string" },
            "errorCode": { "type": "string" }
          }
        }
      }
    }
  ]
}
