apiVersion: v1
kind: Secret
metadata:
  name: autocode-secrets
  namespace: autocode
type: Opaque
stringData:
  # Control Plane
  mvp-db-url: "jdbc:mysql://mysql:3306/mvp_codeops?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC"
  mvp-db-username: "autocode"
  mvp-db-password: "CHANGE_ME"
  mvp-redis-host: "redis"
  mvp-redis-password: "CHANGE_ME"
  mvp-jwt-secret: "CHANGE_ME_TO_RANDOM_64_CHARS"

  # Approval Service
  approval-db-url: "jdbc:mysql://mysql:3306/approval_db?createDatabaseIfNotExist=true"
  approval-db-user: "autocode"
  approval-db-password: "CHANGE_ME"

  # Artifact Service
  artifact-db-url: "jdbc:mysql://mysql:3306/artifact_db?createDatabaseIfNotExist=true"
  artifact-db-user: "autocode"
  artifact-db-password: "CHANGE_ME"

  # Event Service
  event-db-url: "jdbc:mysql://mysql:3306/event_db?createDatabaseIfNotExist=true"
  event-db-user: "autocode"
  event-db-password: "CHANGE_ME"

  # Gateway
  gateway-redis-host: "redis"
  gateway-redis-password: "CHANGE_ME"
