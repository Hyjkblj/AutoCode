{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/manifest/v1/artifact_manifest.v1.schema.json",
  "title": "ArtifactManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "../../events/v1/artifact.schema.json" }
    },
    "defaultArtifactId": { "type": "string", "minLength": 1 }
  }
}
