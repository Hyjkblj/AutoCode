# ============================================================
# Python Agent 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 控制平面配置 ----------
MVP_BASE_URL=http://localhost:8058
MVP_AGENT_TOKEN=your_agent_token
MVP_AGENT_PROFILE=coder

# ---------- 工作空间配置 ----------
# 允许访问的工作空间路径前缀（多个用逗号分隔）
MVP_ALLOWED_WORKSPACE_PREFIXES=/path/to/your/workspace

# ---------- 沙箱配置 ----------
MVP_SANDBOX_BASE_URL=http://127.0.0.1:18091

# ---------- LLM配置 ----------
# 火山引擎Ark
ARK_API_KEY=your_ark_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_CHAT_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# LLM后端: openai, claude
LLM_BACKEND=openai
# LLM模型名称
LLM_MODEL=doubao-seed-2-0-code-preview-260215
