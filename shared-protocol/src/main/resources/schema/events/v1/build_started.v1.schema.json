{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/events/v1/build_started.v1.schema.json",
  "title": "BUILD_STARTED TaskEvent v1",
  "allOf": [
    { "$ref": "task_event.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "BUILD_STARTED" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "buildId": { "type": "string" },
            "tool": { "type": "string" },
            "target": { "type": "string" }
          }
        }
      }
    }
  ]
}

