{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/events/v1/task_started.v1.schema.json",
  "title": "TASK_STARTED TaskEvent v1",
  "allOf": [
    { "$ref": "task_event.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "TASK_STARTED" },
        "payload": {
          "type": "object",
          "required": ["nodeId"],
          "properties": {
            "nodeId": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
