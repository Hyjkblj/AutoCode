# ============================================================
# AutoCode 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 数据库配置 ----------
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_PASSWORD=your_mysql_password

# ---------- Redis配置 ----------
REDIS_PASSWORD=your_redis_password

# ---------- 安全Token ----------
# JWT密钥：至少32字节的随机字符串
JWT_SECRET=your_jwt_secret_at_least_32_bytes_long
# 产物下载共享Token
MVP_ARTIFACTS_DOWNLOAD_SHARED_TOKEN=your_shared_token
# Agent认证Token
AGENT_TOKEN=your_agent_token

# ---------- 产物托管公网地址 ----------
# 部署到公网时设置，例如: http://your-server.com:8058
MVP_ARTIFACTS_HOSTING_PUBLIC_BASE_URL=

# ---------- LLM配置 ----------
# 选择一个LLM后端并配置对应的API密钥
# 火山引擎Ark
ARK_API_KEY=your_ark_api_key
# OpenAI
OPENAI_API_KEY=your_openai_api_key
# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# LLM配置文件路径
LLM_CONFIG_PATH=configs/doubao-seed-2.0-code-high-perf.json
# 提示模式: direct 或 contract
WEB_TEMPLATE_PROMPT_MODE=direct
