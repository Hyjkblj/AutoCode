# ============================================================
# Java Agent 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 控制平面配置 ----------
MVP_BASE_URL=http://localhost:8058
MVP_AGENT_TOKEN=your_agent_token
MVP_NODE_ID=java-sandbox-local
MVP_AGENT_PROFILE=coder

# ---------- 工作空间配置 ----------
# 允许访问的工作空间路径前缀（多个用逗号分隔）
MVP_ALLOWED_WORKSPACE_PREFIXES=/path/to/your/workspace

# ---------- 沙箱配置 ----------
MVP_SANDBOX_PORT=18091
