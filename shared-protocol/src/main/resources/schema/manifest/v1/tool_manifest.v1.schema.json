{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocode.example/schema/manifest/v1/tool_manifest.v1.schema.json",
  "title": "ToolManifest v1",
  "type": "object",
  "required": ["name", "version", "action"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "action": { "type": "string", "minLength": 1 },
    "argsSchema": { "type": "object" },
    "params": {
      "type": "array",
      "items": { "$ref": "#/$defs/toolParamSpec" }
    },
    "permissions": { "$ref": "#/$defs/toolPermissions" }
  },
  "additionalProperties": true,
  "$defs": {
    "toolParamSpec": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "defaultValue": {},
        "enumValues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "toolPermissions": {
      "type": "object",
      "properties": {
        "commandExec": { "type": "boolean" },
        "fileRead": { "type": "boolean" },
        "fileWrite": { "type": "boolean" },
        "networkAccess": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" },
        "riskScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "requiredPolicies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    }
  }
}
