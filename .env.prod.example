# AutoCode Production Environment Variables
# Usage: cp .env.prod.example .env.prod && vim .env.prod

# ─── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_PASSWORD=CHANGE_ME_app_password

# ─── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── JWT ────────────────────────────────────────────────────────
# 必须 >= 32 字节，生产环境用随机生成的值
JWT_SECRET=CHANGE_ME_random_64_chars_minimum

# ─── Agent ──────────────────────────────────────────────────────
AGENT_TOKEN=CHANGE_ME_agent_token

# ─── LLM API ────────────────────────────────────────────────────
ARK_API_KEY=
OPENAI_API_KEY=
LLM_CONFIG_PATH=configs/doubao-seed-2.0-code-high-perf.json

# ─── Grafana ────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
